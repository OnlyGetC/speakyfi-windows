{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Speakyfi",
  "version": "1.6.0",
  "identifier": "com.speakyfi.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Speakyfi",
        "url": "index.html",
        "width": 400,
        "height": 160,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "visible": true,
        "center": false,
        "x": 20,
        "y": 60,
        "skipTaskbar": true,
        "focus": false
      },
      {
        "label": "settings",
        "title": "Speakyfi — Settings",
        "url": "settings.html",
        "width": 700,
        "height": 540,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "transparent": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "title": "Speakyfi"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "OnlyGetC",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
