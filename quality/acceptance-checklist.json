    "env": "RUST_CHECK_STATUS"
  },
  {
    "id": "ci.rust_tests",
    "title": "Rust unit and integration tests pass",
    "method": "github_actions",
    "auto": true,
    "env": "RUST_TEST_STATUS"
  },
  {
    "id": "ci.tauri_build",
    "title": "Tauri Windows build completes",
    "method": "github_actions",
    "auto": true,
