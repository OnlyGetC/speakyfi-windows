  },
  {
    "id": "runtime.tray_settings",
    "title": "Tray icon and settings window work",
    "method": "windows_smoke",
    "auto": false,
    "manual_reason": "Needs Windows shell/tray UI."
  },
  {
    "id": "runtime.ptt_recording",
    "title": "PTT starts and stops recording",
    "method": "manual",
    "auto": false,
