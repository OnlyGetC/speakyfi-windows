    "extension": ".msi"
  },
  {
    "id": "artifact.nsis",
    "title": "NSIS installer artifact exists",
    "method": "artifact_check",
    "auto": true,
    "path": "src-tauri/target/release/bundle/nsis",
    "extension": ".exe"
  },
  {
    "id": "artifact.portable_exe",
    "title": "Portable EXE artifact exists",
    "method": "artifact_check",
    "auto": true,
    "path": "src-tauri/target/release",
    "filename": "speakyfi.exe"
  },
  {
    "id": "diagnostics.config",
    "title": "Diagnostics command compiles and report shape is test-covered",
